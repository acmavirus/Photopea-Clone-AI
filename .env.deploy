# CẤU HÌNH TRIỂN KHAI VPS (VPS DEPLOYMENT CONFIGURATION)
# Hãy điền thông tin VPS của bạn dưới đây trước khi chạy .\deploy.ps1

VPS_IP="15.235.199.163"                  # Địa chỉ IP của VPS
VPS_PORT="2404"              # Cổng SSH của VPS
VPS_USER="root"            # Tài khoản đăng nhập SSH
VPS_KEY_PATH="~/.ssh/id_rsa" # Đường dẫn tới file private key (nếu dùng SSH Key)
VPS_PROJECT_DIR="/var/www/photoeditor.thuc.me" # Đường dẫn thư mục lưu dự án trên VPS
VPS_APP_PORT="8085"                  # Cổng ứng dụng trên VPS (ví dụ: 8085)
